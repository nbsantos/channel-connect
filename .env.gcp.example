# Copy to .env.gcp and export before running ./scripts/gcp-deploy.sh

# Required
GCP_PROJECT_ID=your-gcp-project-id

# Optional
GCP_REGION=us-central1
GKE_CLUSTER=channel-connect
ARTIFACT_REPO=channel-connect

# Set a stable secret across deploys (generate with: openssl rand -hex 32)
# SESSION_SECRET=

# Seed demo accounts on first pod boot (recommended for demos only)
# SEED_DATABASE=true

# Public hostname (managed TLS via GKE Ingress)
APP_DOMAIN=app.channel-connect.com

# Create GKE Autopilot cluster on first deploy
# CREATE_CLUSTER=1
