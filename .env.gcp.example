# Copy to .env.gcp and export before running ./scripts/gcp-deploy.sh

# Required
GCP_PROJECT_ID=your-gcp-project-id

# Optional
GCP_REGION=us-central1
GKE_CLUSTER=channel-connect
ARTIFACT_REPO=channel-connect

# Cloud SQL (PostgreSQL)
CLOUDSQL_INSTANCE=channel-connect-db
CLOUDSQL_EDITION=ENTERPRISE
CLOUDSQL_TIER=db-f1-micro
# For ENTERPRISE_PLUS use a tier like: CLOUDSQL_TIER=db-perf-optimized-N-2
DB_NAME=channel_connect
DB_USER=channel_connect
# DB_PASSWORD=  # reused from the Kubernetes secret when unset

# Set a stable session secret across deploys (generate with: openssl rand -hex 32)
# SESSION_SECRET=

# Seed demo accounts when the database is empty (recommended for demos only)
# SEED_DATABASE=true

# Reset and re-seed even when data exists
# FORCE_SEED=1

# Public hostname (managed TLS via GKE Ingress)
APP_DOMAIN=app.channel-connect.com

# Create GKE Autopilot cluster on first deploy
# CREATE_CLUSTER=1
